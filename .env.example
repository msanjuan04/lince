# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=                      # Postgres connection string para Prisma

# Auth.js v5
AUTH_SECRET=                       # generar con `openssl rand -hex 32`
AUTH_URL=http://localhost:3000

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Maps Platform
GOOGLE_MAPS_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=                 # ej: notify@lince.cat

# WhatsApp Cloud (Meta) — pausado por ahora, canal principal es Telegram.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Telegram Bot (canal de envío del informe Pulse semanal)
# 1) Crear bot con @BotFather en Telegram → copiar el token aquí.
TELEGRAM_BOT_TOKEN=
# 2a) Modo simple: lista de chat_ids separados por coma, todos reciben el mismo rol.
#     Para descubrir los chat_ids: pnpm --filter @lince/ai telegram:list-chats
TELEGRAM_CHAT_IDS=
# 2b) Modo con rol por chat (CSV o JSON). Si está definido, tiene prioridad sobre TELEGRAM_CHAT_IDS.
#     CSV:  TELEGRAM_PULSE_RECIPIENTS=123456:inversor_directo,-1009876:flipper
#     JSON: TELEGRAM_PULSE_RECIPIENTS='[{"chatId":"123456","role":"inversor_directo"}]'
TELEGRAM_PULSE_RECIPIENTS=

# Replicate
REPLICATE_API_TOKEN=

# Redis
REDIS_URL=

# DigitalOcean (workers deployment)
DO_API_TOKEN=
DO_DROPLET_IP=

# Misc
NODE_ENV=development
LOG_LEVEL=debug
