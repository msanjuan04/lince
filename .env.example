# Auth.js v5
AUTH_SECRET=                       # generar con `openssl rand -hex 32`
AUTH_URL=http://localhost:3000

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Maps Platform
GOOGLE_MAPS_API_KEY=

# Resend
RESEND_API_KEY=
