# WhatsApp Cloud (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Replicate
REPLICATE_API_TOKEN=

# Redis
REDIS_URL=

# DigitalOcean (workers deployment)
DO_API_TOKEN=
DO_DROPLET_IP=

# Misc
NODE_ENV=development
LOG_LEVEL=debug
