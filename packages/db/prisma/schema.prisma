// Lince — schema base. Ver CLAUDE.md sección 4 para SQL equivalente y notas de modelado.
// `properties` y `crawler_runs` son globales (sin agency_id). El resto es multi-tenant con RLS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --------------------------------------------------------------------------
// Enums
// --------------------------------------------------------------------------

enum AgencyPlan {
  basic
  pro
  elite
  founder
}

enum AgencyMemberRole {
  owner
  agent
  admin
}

enum CaptureStatus {
  new
  contacted
  meeting
  signed
  lost
}

enum ListingStatus {
  draft
  live
  sold
  withdrawn
}

enum ListingLeadStatus {
  new
  contacted
  qualified
  lost
  closed
}

// --------------------------------------------------------------------------
// Tenancy
// --------------------------------------------------------------------------

model Agency {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  plan      AgencyPlan
  active    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  members  AgencyMember[]
  zones    Zone[]
  captures Capture[]
  listings Listing[]
  leads    ListingLead[]
  tracks   PropertyTrack[]

  @@map("agencies")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  memberships AgencyMember[]

  @@map("users")
}

model AgencyMember {
  agencyId String           @map("agency_id") @db.Uuid
  userId   String           @map("user_id") @db.Uuid
  role     AgencyMemberRole

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([agencyId, userId])
  @@map("agency_members")
}

// --------------------------------------------------------------------------
// Catálogo global de propiedades capturadas (sin agency_id — visibilidad por zonas)
// --------------------------------------------------------------------------

model Property {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source            String
  sourceId          String   @map("source_id")
  sourceUrl         String?  @map("source_url")
  type              String?
  address           String?
  city              String?
  postalCode        String?  @map("postal_code")
  province          String?
  lat               Float?   @db.DoublePrecision
  lng               Float?   @db.DoublePrecision
  cadastralRef      String?  @map("cadastral_ref")
  m2                Int?
  rooms             Int?
  bathrooms         Int?
  yearBuilt         Int?     @map("year_built")
  price             Decimal? @db.Decimal(12, 2)
  pricePerM2        Decimal? @map("price_per_m2") @db.Decimal(10, 2)
  zoneAvgPricePerM2 Decimal? @map("zone_avg_price_per_m2") @db.Decimal(10, 2)
  opportunityScore  Decimal? @map("opportunity_score") @db.Decimal(5, 2)
  status            String?

  // Descripción y huella para detección de cambios (Fase 2)
  description       String?  @db.Text
  descriptionHash   String?  @map("description_hash")

  // Atributos para Bucket E (premium oculto) y Bucket C (estado/reforma)
  hasTerrace        Boolean? @map("has_terrace")
  hasElevator       Boolean? @map("has_elevator")
  floor             String?
  orientation       String?
  condition         String?

  // Atributos para Bucket B (origen institucional / subasta)
  isBankOwned          Boolean? @map("is_bank_owned")
  isAuction            Boolean? @map("is_auction")
  auctionStartingPrice Decimal? @map("auction_starting_price") @db.Decimal(12, 2)

  // Banderas rojas detectadas en descripción (okupación, VPO, cargas, etc.)
  redFlags          String[] @map("red_flags")

  rawData           Json?    @map("raw_data") @db.JsonB
  firstSeen         DateTime @default(now()) @map("first_seen") @db.Timestamptz()
  lastSeen          DateTime @default(now()) @map("last_seen") @db.Timestamptz()

  captures Capture[]

  priceHistory       PriceHistory[]
  descriptionHistory DescriptionHistory[]
  tracks             PropertyTrack[]

  @@unique([source, sourceId])
  @@index([postalCode])
  @@index([opportunityScore(sort: Desc)])
  @@index([lat, lng])
  @@index([isAuction])
  @@index([isBankOwned])
  @@map("properties")
}

// --------------------------------------------------------------------------
// Histórico — Fase 2: detección de rebajas (Bucket A — vendedor desesperado)
// --------------------------------------------------------------------------

/**
 * Cada cambio de precio detectado entre runs queda registrado aquí. Permite
 * calcular: número de rebajas en N semanas, magnitud acumulada, tiempo desde
 * última rebaja. Input principal del Bucket A (vendedor desesperado).
 */
model PriceHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId   String   @map("property_id") @db.Uuid
  oldPrice     Decimal? @map("old_price") @db.Decimal(12, 2)
  newPrice     Decimal  @map("new_price") @db.Decimal(12, 2)
  deltaPct     Decimal? @map("delta_pct") @db.Decimal(6, 2)
  observedAt   DateTime @default(now()) @map("observed_at") @db.Timestamptz()

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, observedAt(sort: Desc)])
  @@index([observedAt])
  @@map("price_history")
}

/**
 * Cambios de descripción entre runs. Útil para detectar "señales de urgencia"
 * que aparecen tarde en el anuncio (ej. "se escuchan ofertas", "por traslado").
 * No guardamos el texto completo cada vez — solo hash + un snippet corto.
 */
model DescriptionHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId      String   @map("property_id") @db.Uuid
  oldHash         String?  @map("old_hash")
  newHash         String   @map("new_hash")
  snippet         String?  @db.Text
  observedAt      DateTime @default(now()) @map("observed_at") @db.Timestamptz()

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, observedAt(sort: Desc)])
  @@map("description_history")
}

// --------------------------------------------------------------------------
// Por-agency: zonas monitorizadas, captación, listings, leads compradores
// --------------------------------------------------------------------------

model Zone {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agencyId      String   @map("agency_id") @db.Uuid
  name          String?
  geometry      Json?    @db.JsonB
  postalCodes   String[] @map("postal_codes")
  filters       Json?    @db.JsonB
  alertChannels String[] @map("alert_channels")
  // Destinatario para notificaciones de matches en esta zona.
  alertPhoneE164 String? @map("alert_phone_e164")
  alertEmail    String?  @map("alert_email")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agency Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  alerts ZoneAlert[]

  @@index([agencyId, active])
  @@map("zones")
}

// --------------------------------------------------------------------------
// Alertas Fase 3: el sistema evalúa zonas tras cada crawl y registra una
// fila por cada trigger (propiedad nueva, rebaja relevante, score alto).
// La fila contiene el estado de envío para auditoría y reintentos.
// --------------------------------------------------------------------------

enum ZoneAlertTrigger {
  new_property      @map("new_property")
  price_drop        @map("price_drop")
  high_score        @map("high_score")
}

enum ZoneAlertStatus {
  pending
  sent
  failed
  skipped
}

// --------------------------------------------------------------------------
// CRM personal del inversor — Fase 4: marcar propiedades como tracked,
// notas privadas, status de gestión, target price (oferta máxima).
// --------------------------------------------------------------------------

enum PropertyTrackStatus {
  watching   // marcada para seguimiento, aún no he hecho nada
  interested // interesado, analizando
  contacted  // contacté con vendedor/agencia
  viewed     // visité el inmueble
  offering   // negociando oferta
  rejected   // descartada
  bought     // adquirida
}

model PropertyTrack {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agencyId       String              @map("agency_id") @db.Uuid
  propertyId     String              @map("property_id") @db.Uuid
  status         PropertyTrackStatus @default(watching)
  notes          String?             @db.Text
  targetPriceEur Decimal?            @map("target_price_eur") @db.Decimal(12, 2)
  contactedAt    DateTime?           @map("contacted_at") @db.Timestamptz()
  viewedAt       DateTime?           @map("viewed_at") @db.Timestamptz()
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz()

  agency   Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, propertyId])
  @@index([agencyId, status])
  @@map("property_tracks")
}

model ZoneAlert {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zoneId      String           @map("zone_id") @db.Uuid
  propertyId  String           @map("property_id") @db.Uuid
  trigger     ZoneAlertTrigger
  channel     String           // 'whatsapp' | 'email' (extensible)
  status      ZoneAlertStatus  @default(pending)
  payload     Json?            @db.JsonB
  error       String?
  sentAt      DateTime?        @map("sent_at") @db.Timestamptz()
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  // Dedup: una alerta por (zona, propiedad, trigger). Evita reenviar la misma
  // notificación si el crawler vuelve a observar la propiedad sin cambios.
  @@unique([zoneId, propertyId, trigger])
  @@index([status, createdAt])
  @@map("zone_alerts")
}

model Capture {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agencyId       String         @map("agency_id") @db.Uuid
  propertyId     String?        @map("property_id") @db.Uuid
  status         CaptureStatus?
  notes          String?
  ownerName      String?        @map("owner_name")
  ownerPhone     String?        @map("owner_phone")
  ownerEmail     String?        @map("owner_email")
  proposalPdfUrl String?        @map("proposal_pdf_url")
  contactedAt    DateTime?      @map("contacted_at") @db.Timestamptz()
  signedAt       DateTime?      @map("signed_at") @db.Timestamptz()
  dealValue      Decimal?       @map("deal_value") @db.Decimal(12, 2)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  agency   Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id])
  listings Listing[]

  @@map("captures")
}

model Listing {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  captureId     String?        @map("capture_id") @db.Uuid
  agencyId      String         @map("agency_id") @db.Uuid
  fichaSeoText  String?        @map("ficha_seo_text")
  photos        Json?          @db.JsonB
  stagingPhotos Json?          @map("staging_photos") @db.JsonB
  price         Decimal?       @db.Decimal(12, 2)
  status        ListingStatus?
  distributedTo String[]       @map("distributed_to")
  viewsCount    Int            @default(0) @map("views_count")
  leadsCount    Int            @default(0) @map("leads_count")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  capture Capture?      @relation(fields: [captureId], references: [id])
  agency  Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  leads   ListingLead[]

  @@map("listings")
}

model ListingLead {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId String?            @map("listing_id") @db.Uuid
  agencyId  String?            @map("agency_id") @db.Uuid
  name      String?
  email     String?
  phone     String?
  source    String?
  message   String?
  status    ListingLeadStatus?
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  listing Listing? @relation(fields: [listingId], references: [id])
  agency  Agency?  @relation(fields: [agencyId], references: [id])

  @@map("listing_leads")
}

// --------------------------------------------------------------------------
// Auditoría
// --------------------------------------------------------------------------

model CrawlerRun {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source            String
  status            String?
  propertiesFound   Int?      @map("properties_found")
  propertiesNew     Int?      @map("properties_new")
  propertiesUpdated Int?      @map("properties_updated")
  errors            Json?     @db.JsonB
  startedAt         DateTime? @map("started_at") @db.Timestamptz()
  endedAt           DateTime? @map("ended_at") @db.Timestamptz()

  @@map("crawler_runs")
}
