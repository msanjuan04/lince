// Lince — schema base. Ver CLAUDE.md sección 4 para SQL equivalente y notas de modelado.
// `properties` y `crawler_runs` son globales (sin agency_id). El resto es multi-tenant con RLS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --------------------------------------------------------------------------
// Enums
// --------------------------------------------------------------------------

enum AgencyPlan {
  basic
  pro
  elite
  founder
}

enum AgencyMemberRole {
  owner
  agent
  admin
}

enum CaptureStatus {
  new
  contacted
  meeting
  signed
  lost
}

enum ListingStatus {
  draft
  live
  sold
  withdrawn
}

enum ListingLeadStatus {
  new
  contacted
  qualified
  lost
  closed
}

// --------------------------------------------------------------------------
// Tenancy
// --------------------------------------------------------------------------

model Agency {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  plan      AgencyPlan
  active    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  members  AgencyMember[]
  zones    Zone[]
  captures Capture[]
  listings Listing[]
  leads    ListingLead[]

  @@map("agencies")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  memberships AgencyMember[]

  @@map("users")
}

model AgencyMember {
  agencyId String           @map("agency_id") @db.Uuid
  userId   String           @map("user_id") @db.Uuid
  role     AgencyMemberRole

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([agencyId, userId])
  @@map("agency_members")
}

// --------------------------------------------------------------------------
// Catálogo global de propiedades capturadas (sin agency_id — visibilidad por zonas)
// --------------------------------------------------------------------------

model Property {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source            String
  sourceId          String   @map("source_id")
  sourceUrl         String?  @map("source_url")
  type              String?
  address           String?
  city              String?
  postalCode        String?  @map("postal_code")
  province          String?
  lat               Float?   @db.DoublePrecision
  lng               Float?   @db.DoublePrecision
  cadastralRef      String?  @map("cadastral_ref")
  m2                Int?
  rooms             Int?
  bathrooms         Int?
  yearBuilt         Int?     @map("year_built")
  price             Decimal? @db.Decimal(12, 2)
  pricePerM2        Decimal? @map("price_per_m2") @db.Decimal(10, 2)
  zoneAvgPricePerM2 Decimal? @map("zone_avg_price_per_m2") @db.Decimal(10, 2)
  opportunityScore  Decimal? @map("opportunity_score") @db.Decimal(5, 2)
  status            String?

  // Descripción y huella para detección de cambios (Fase 2)
  description       String?  @db.Text
  descriptionHash   String?  @map("description_hash")

  // Atributos para Bucket E (premium oculto) y Bucket C (estado/reforma)
  hasTerrace        Boolean? @map("has_terrace")
  hasElevator       Boolean? @map("has_elevator")
  floor             String?
  orientation       String?
  condition         String?

  // Atributos para Bucket B (origen institucional / subasta)
  isBankOwned          Boolean? @map("is_bank_owned")
  isAuction            Boolean? @map("is_auction")
  auctionStartingPrice Decimal? @map("auction_starting_price") @db.Decimal(12, 2)

  // Banderas rojas detectadas en descripción (okupación, VPO, cargas, etc.)
  redFlags          String[] @map("red_flags")

  rawData           Json?    @map("raw_data") @db.JsonB
  firstSeen         DateTime @default(now()) @map("first_seen") @db.Timestamptz()
  lastSeen          DateTime @default(now()) @map("last_seen") @db.Timestamptz()

  captures Capture[]

  @@unique([source, sourceId])
  @@index([postalCode])
  @@index([opportunityScore(sort: Desc)])
  @@index([lat, lng])
  @@index([isAuction])
  @@index([isBankOwned])
  @@map("properties")
}

// --------------------------------------------------------------------------
// Por-agency: zonas monitorizadas, captación, listings, leads compradores
// --------------------------------------------------------------------------

model Zone {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agencyId      String   @map("agency_id") @db.Uuid
  name          String?
  geometry      Json?    @db.JsonB
  postalCodes   String[] @map("postal_codes")
  filters       Json?    @db.JsonB
  alertChannels String[] @map("alert_channels")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("zones")
}

model Capture {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agencyId       String         @map("agency_id") @db.Uuid
  propertyId     String?        @map("property_id") @db.Uuid
  status         CaptureStatus?
  notes          String?
  ownerName      String?        @map("owner_name")
  ownerPhone     String?        @map("owner_phone")
  ownerEmail     String?        @map("owner_email")
  proposalPdfUrl String?        @map("proposal_pdf_url")
  contactedAt    DateTime?      @map("contacted_at") @db.Timestamptz()
  signedAt       DateTime?      @map("signed_at") @db.Timestamptz()
  dealValue      Decimal?       @map("deal_value") @db.Decimal(12, 2)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  agency   Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id])
  listings Listing[]

  @@map("captures")
}

model Listing {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  captureId     String?        @map("capture_id") @db.Uuid
  agencyId      String         @map("agency_id") @db.Uuid
  fichaSeoText  String?        @map("ficha_seo_text")
  photos        Json?          @db.JsonB
  stagingPhotos Json?          @map("staging_photos") @db.JsonB
  price         Decimal?       @db.Decimal(12, 2)
  status        ListingStatus?
  distributedTo String[]       @map("distributed_to")
  viewsCount    Int            @default(0) @map("views_count")
  leadsCount    Int            @default(0) @map("leads_count")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  capture Capture?      @relation(fields: [captureId], references: [id])
  agency  Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  leads   ListingLead[]

  @@map("listings")
}

model ListingLead {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId String?            @map("listing_id") @db.Uuid
  agencyId  String?            @map("agency_id") @db.Uuid
  name      String?
  email     String?
  phone     String?
  source    String?
  message   String?
  status    ListingLeadStatus?
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  listing Listing? @relation(fields: [listingId], references: [id])
  agency  Agency?  @relation(fields: [agencyId], references: [id])

  @@map("listing_leads")
}

// --------------------------------------------------------------------------
// Auditoría
// --------------------------------------------------------------------------

model CrawlerRun {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source            String
  status            String?
  propertiesFound   Int?      @map("properties_found")
  propertiesNew     Int?      @map("properties_new")
  propertiesUpdated Int?      @map("properties_updated")
  errors            Json?     @db.JsonB
  startedAt         DateTime? @map("started_at") @db.Timestamptz()
  endedAt           DateTime? @map("ended_at") @db.Timestamptz()

  @@map("crawler_runs")
}
